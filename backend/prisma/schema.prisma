generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String  @id @default(uuid())
  name              String
  email             String  @unique
  phone             String? @unique
  password          String?
  googleId          String? @unique
  role              Role?
  isProfileComplete Boolean @default(false)
  isActive          Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customerProfile     CustomerProfile?
  driverProfile       DriverProfile?
  wallet              Wallet?
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  savedPlaces         SavedPlace[]
  Notification        Notification[]

  ridesAsCustomer Ride[] @relation("CustomerRide")
  ridesAsDriver   Ride[] @relation("DriverRide")

  driverRatings   Rating[] @relation("DriverRating")
  customerRatings Rating[] @relation("CustomerRating")
}

model CustomerProfile {
  id       String   @id @default(uuid())
  userId   String   @unique
  userType UserType @default(individual)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DriverProfile {
  id          String      @id @default(uuid())
  userId      String      @unique

  vehicleType VehicleType
  licenseNo   String?
  licenseExpiry DateTime?
  licenseDocumentUrl  String?

  isApproved  Boolean     @default(false)
  rejectionReason String?

  rating      Float       @default(0)
  totalTrips  Int         @default(0)

  isOnline    Boolean     @default(false)
  isBusy      Boolean     @default(false)

  lastSeen    DateTime?

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles Vehicle[]
  documents DriverDocument[]
  location DriverLocation?
}

model Ride {
  id String @id @default(uuid())

  customerId String
  driverId   String?

  vehicleType VehicleType

  pickupLat Float
  pickupLng Float
  dropLat   Float
  dropLng   Float

  distanceKm  Float
  price       Float

  status RideStatus @default(requested)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cancelReason String?

  customer User  @relation("CustomerRide", fields: [customerId], references: [id])
  driver   User? @relation("DriverRide", fields: [driverId], references: [id])

  payment Payment?
  rating  Rating?

  dispute Dispute?

  statusHistory RideStatusHistory[]
  rideLocation  RideLocation?

  @@index([customerId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
}

model Vehicle {
  id       String @id @default(uuid())
  driverId String

  type        VehicleType
  model       String
  brand       String?
  plateNumber String
  capacity    Int?

  color       String?
  year        Int?

  isVerified  Boolean @default(false)

  driver DriverProfile @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model DriverLocation {
  id       String @id @default(uuid())
  driverId String @unique

  lat       Float
  lng       Float
  updatedAt DateTime @updatedAt

  driver DriverProfile @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model DriverDocument {
  id       String @id @default(uuid())
  driverId String

  type DocumentType
  url  String

  expiryDate DateTime?
  isVerified Boolean @default(false)

  createdAt DateTime @default(now())

  driver DriverProfile @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model RideStatusHistory {
  id        String     @id @default(uuid())
  rideId    String
  status    RideStatus
  createdAt DateTime   @default(now())

  ride Ride @relation(fields: [rideId], references: [id])
}

model Payment {
  id     String @id @default(uuid())
  rideId String @unique

  amount Float

  adminCommission   Float
  driverEarning     Float
  
  method PaymentMethod
  status PaymentStatus

  createdAt DateTime @default(now())

  ride Ride @relation(fields: [rideId], references: [id])
}

model SurgePricing {
  id String @id @default(uuid())

  city       String
  multiplier Float

  active    Boolean
  startTime DateTime
  endTime   DateTime
}

model Wallet {
  id      String @id @default(uuid())
  userId  String @unique
  balance Float  @default(0)

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id       String @id @default(uuid())
  walletId String

  amount Float
  type   TransactionType
  reason String?

  createdAt DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Rating {
  id String @id @default(uuid())

  rideId     String @unique
  driverId   String
  customerId String

  rating Int
  review String?

  createdAt DateTime @default(now())

  ride     Ride @relation(fields: [rideId], references: [id])
  driver   User @relation("DriverRating", fields: [driverId], references: [id])
  customer User @relation("CustomerRating", fields: [customerId], references: [id])
}

model RideLocation {
  id     String @id @default(uuid())
  rideId String @unique

  pickupAddress String
  dropAddress   String

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)
}

model SavedPlace {
  id      String @id @default(uuid())
  userId  String

  label   String
  address String
  type    String 
  lat     Float
  lng     Float

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String

  title     String
  message   String
  type      NotificationType

  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Dispute {
  id          String        @id @default(uuid())
  rideId      String        @unique
  ride        Ride          @relation(fields: [rideId], references: [id])
  
  raisedBy    String        // "customer" or "driver"
  reason      String
  description String?
  
  status      DisputeStatus @default(pending)
  priority    Priority      @default(medium)
  
  amount      Float?        // Disputed amount
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model PromoCode {
  id            String      @id @default(uuid())
  code          String      @unique // e.g., "WELCOME20"
  description   String?
  
  discountType  DiscountType @default(percentage)
  discountValue Float       // 20 for 20% or 100 for ₹100
  
  minPrice      Float       @default(0)    // Minimum ride fare to apply
  maxDiscount   Float?      // Cap for percentage discounts
  
  usageLimit    Int         @default(100)  // Max total uses
  usedCount     Int         @default(0)
  
  expiryDate    DateTime
  isActive      Boolean     @default(true)
  
  createdAt     DateTime    @default(now())
}

model GeoZone {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  
  // Coordinates for the center of the zone
  centerLat     Float
  centerLng     Float
  radiusKm      Float    @default(5) 
  
  isActive      Boolean  @default(true)
  surgeEnabled  Boolean  @default(false)
  baseMultiplier Float   @default(1.0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  adminId     String
  adminName   String   // Snapshot for quick viewing
  
  action      String   // e.g., "PROMO_CREATED", "DRIVER_BLOCKED", "SURGE_UPDATED"
  entity      String   // e.g., "PromoCode", "DriverProfile", "SystemSetting"
  entityId    String?
  
  oldValue    Json?    // State before change
  newValue    Json?    // State after change
  
  ipAddress   String?
  severity    String   @default("info") // info, warning, critical

  createdAt   DateTime @default(now())
}

enum Role {
  customer
  driver
  admin
}

enum UserType {
  individual
  business
}

enum RideStatus {
  requested
  driver_assigned
  driver_arriving
  ride_started
  completed
  cancelled
}

enum PaymentMethod {
  wallet
  card
  cash
  upi_driver
}

enum NotificationType {
  ride_request
  ride_update
  document_status
  payment
  general
}

enum DisputeStatus {
  pending
  under_review
  resolved
  refunded
}

enum Priority {
  low
  medium
  high
  urgent
}

enum DiscountType {
  percentage
  flat
}

enum DocumentType {
  license
  rc
  insurance
  pollution
  aadhaar
}

enum PaymentStatus {
  pending
  paid
  failed
}

enum TransactionType {
  credit
  debit
}

enum VehicleType {
  bike
  pickups
  mini_truck
  truck
}
